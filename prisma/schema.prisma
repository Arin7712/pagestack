// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement())
  clerkId String @unique
  email String  @unique
  name  String
  profileImage String
  pages Page[]
} 

model Page {
  id Int @id @default(autoincrement())
  authorId String
  slug String @unique
  pageName String
  description String
  favIcon String
  startups Startups[]
  author User @relation(fields: [authorId], references: [clerkId])
}

model Startups {
  id Int @id @default(autoincrement()) 
  authorId Int
  name String
  description String
  favIcon String
  revenue Int
  userCount Int
  author Page @relation(fields: [authorId], references: [id])
}